<mujoco model="standing_humanoid">
  <compiler angle="radian"/>
  <option gravity="0 0 -9.81" timestep="0.01"/>

  <worldbody>
    <geom name="ground" type="plane" size="10 10 0.1" rgba="0.8 0.8 0.8 1"/>

    <!-- 根节点：把初始位置直接设为站立状态 -->
    <body name="root" pos="0 0 1.0" quat="1 0 0 0">
      <joint name="root_x" type="slide" axis="1 0 0"/>
      <joint name="root_y" type="slide" axis="0 1 0"/>
      <joint name="root_z" type="slide" axis="0 0 1"/>
      <joint name="root_rot_x" type="hinge" axis="1 0 0"/>
      <joint name="root_rot_y" type="hinge" axis="0 1 0"/>
      <joint name="root_rot_z" type="hinge" axis="0 0 1"/>

      <!-- 躯干 -->
      <geom type="capsule" size="0.15 0.3" fromto="0 0 -0.3 0 0 0.3" rgba="0.2 0.6 1 1"/>

      <!-- 头部 -->
      <body name="head" pos="0 0 0.4">
        <geom type="sphere" size="0.12" rgba="0.9 0.7 0.5 1"/>
      </body>

      <!-- 右臂 -->
      <body name="right_arm" pos="0.18 0 0.1">
        <geom type="capsule" size="0.04 0.22" fromto="0 0 0 0 0 -0.25" rgba="0.9 0.9 0.9 1"/>
      </body>

      <!-- 左臂 -->
      <body name="left_arm" pos="-0.18 0 0.1">
        <geom type="capsule" size="0.04 0.22" fromto="0 0 0 0 0 -0.25" rgba="0.9 0.9 0.9 1"/>
      </body>

      <!-- 右腿 -->
      <body name="right_leg" pos="0.12 0 -0.35">
        <geom type="capsule" size="0.06 0.25" fromto="0 0 0 0 0 -0.3" rgba="0.9 0.9 0.9 1"/>
        <body name="right_shin" pos="0 0 -0.3">
          <geom type="capsule" size="0.05 0.25" fromto="0 0 0 0 0 -0.3" rgba="0.9 0.9 0.9 1"/>
          <body name="right_foot" pos="0 0 -0.3">
            <geom type="box" size="0.08 0.05 0.03" rgba="0.6 0.6 0.6 1"/>
          </body>
        </body>
      </body>

      <!-- 左腿 -->
      <body name="left_leg" pos="-0.12 0 -0.35">
        <geom type="capsule" size="0.06 0.25" fromto="0 0 0 0 0 -0.3" rgba="0.9 0.9 0.9 1"/>
        <body name="left_shin" pos="0 0 -0.3">
          <geom type="capsule" size="0.05 0.25" fromto="0 0 0 0 0 -0.3" rgba="0.9 0.9 0.9 1"/>
          <body name="left_foot" pos="0 0 -0.3">
            <geom type="box" size="0.08 0.05 0.03" rgba="0.6 0.6 0.6 1"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>
</mujoco>